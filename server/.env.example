# Must match Vite proxy target (vite.config.ts). Default: 10000 for local dev.
PORT=10000
DATABASE_URL=postgresql://user:password@localhost:5432/provenhire
JWT_SECRET=change-me
BASE_URL=http://localhost:5173

# AI features (resume parsing, interview eval, assignment gen) - free at aistudio.google.com/apikey
# GEMINI_API_KEY=your-gemini-key

# MVP: Using Google Meet. Daily.co disabled. Uncomment when budget allows.
# DAILY_API_KEY=your_daily_api_key
# DAILY_DOMAIN=provenhire

# Email - Resend. Add your API key from resend.com
# For delivery to real inboxes: verify domain at resend.com/domains, then set EMAIL_FROM
# RESEND_API_KEY=re_xxxx
# EMAIL_FROM=ProvenHire <noreply@yourdomain.com>
#
# Optional fallback - Gmail SMTP when Resend fails:
# GMAIL_USER=your-email@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Test interviewer (run: npm run seed:interviewer)
# interviewer@test.provenhire.com / Test123456

# Test admin (run: npm run seed:admin)
# admin@test.provenhire.com / Admin123456

# Verification code: default is to display on signup page (testing/virtual deployment).
# Set to "false" when using real email delivery (Resend/Gmail) in production.
# DISPLAY_VERIFICATION_CODE_ON_PAGE=false

# Google Sign-In (Firebase)
# Option A: Service account JSON file path
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json
#
# Option B: Env vars (for Render, Vercel, etc.)
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# AI Proctoring (Python FastAPI + OpenCV + YOLO). Default: http://127.0.0.1:8001
# AI_PROCTOR_URL=http://127.0.0.1:8001

# Code execution for DSA round (optional). Defaults to public Judge0 CE.
# For production or higher limits, consider self-hosting Judge0: https://github.com/judge0/judge0
# JUDGE0_CE_URL=https://ce.judge0.com
