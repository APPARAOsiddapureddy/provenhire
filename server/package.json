{
  "name": "provenhire-server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "tsx watch server.ts",
    "build": "tsc -p tsconfig.json && mkdir -p dist/data && cp src/data/aptitude-questions.json dist/data/",
    "start": "prisma migrate deploy && node dist/server.js",
    "prisma": "prisma",
    "migrate": "prisma migrate dev",
    "generate": "prisma generate",
    "migrate:legacy": "tsx src/utils/migrate.ts",
    "seed:interviewer": "tsx prisma/seed-interviewer.ts"
  },
  "dependencies": {
    "@google/genai": "^1.43.0",
    "@prisma/client": "^5.20.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.11.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.73.1",
    "pdf-parse": "^2.4.5",
    "pino": "^9.4.0",
    "pino-http": "^9.0.0",
    "resend": "^6.9.3",
    "uuid": "^9.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.16.5",
    "prisma": "^5.20.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.3"
  }
}
