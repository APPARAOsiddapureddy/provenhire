{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://provenhire-server1.onrender.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://provenhire-server1.onrender.com/uploads/:path*"
    },
    {
      "source": "/diagnostic",
      "destination": "https://provenhire-server1.onrender.com/diagnostic"
    },
    { "source": "/(.*)", "destination": "/" }
  ]
}
