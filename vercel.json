{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin-allow-popups" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://provenhire-updated.onrender.com/api/:path*"
    },
    {
      "source": "/health",
      "destination": "https://provenhire-updated.onrender.com/health"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://provenhire-updated.onrender.com/uploads/:path*"
    },
    {
      "source": "/diagnostic",
      "destination": "https://provenhire-updated.onrender.com/diagnostic"
    },
    { "source": "/((?!assets/).*)", "destination": "/" }
  ]
}
