{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "provenhire.in" }],
      "destination": "https://www.provenhire.in/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin-allow-popups" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(favicon.*|og-image.*|logo.*|sitemap.xml|robots.txt)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://provenhire-updated.onrender.com/api/:path*"
    },
    {
      "source": "/health",
      "destination": "https://provenhire-updated.onrender.com/health"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://provenhire-updated.onrender.com/uploads/:path*"
    },
    {
      "source": "/diagnostic",
      "destination": "https://provenhire-updated.onrender.com/diagnostic"
    },
    { "source": "/((?!assets/).*)", "destination": "/" }
  ]
}
